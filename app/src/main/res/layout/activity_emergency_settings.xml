<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- 頂部標題欄 - 固定 -->
    <LinearLayout
        android:id="@+id/titleBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/background_dark"
        android:padding="20dp"
        android:gravity="center_vertical"
        android:minHeight="72dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 返回按鈕 - 更大更易點擊 -->
        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/button_square_background"
            android:backgroundTint="@color/menu_blue"
            android:src="@drawable/ic_back_arrow_white"
            android:scaleType="center"
            android:contentDescription="@string/back_button_desc_emergency"
            android:minWidth="72dp"
            android:minHeight="72dp"
            android:layout_marginEnd="16dp" />

        <!-- 標題 - 更大字體 -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/emergency_settings_title"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center_vertical|start"
            android:minHeight="72dp"
            android:contentDescription="@string/emergency_settings_page_desc"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="20sp"
            android:autoSizeMaxTextSize="28sp"
            android:maxLines="2" />

    </LinearLayout>

    <!-- 可滾動內容區域 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:paddingHorizontal="20dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/titleBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp">

            <!-- 添加聯絡人卡片 - 大卡片設計 -->
            <LinearLayout
                android:id="@+id/addContactSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="24dp"
                android:layout_marginBottom="20dp"
                android:elevation="4dp"
                android:minHeight="200dp">

                <!-- 標題 - 更大更清晰 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/add_emergency_contact_title"
                    android:textColor="@color/primary_blue"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp"
                    android:minHeight="32dp"
                    android:contentDescription="添加緊急聯絡人標題" />

                <!-- 輸入框和按鈕區域 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <!-- 輸入框 - 更大更高 -->
                    <EditText
                        android:id="@+id/newContactEditText"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:hint="@string/enter_phone_number"
                        android:textColor="@color/white"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="20sp"
                        android:background="@drawable/edit_text_background"
                        android:padding="20dp"
                        android:inputType="phone"
                        android:minHeight="80dp"
                        android:contentDescription="@string/enter_phone_number_desc"
                        android:layout_marginBottom="16dp" />

                    <!-- 添加按鈕 - 大按鈕 -->
                    <Button
                        android:id="@+id/addContactButton"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:text="@string/add_button"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:background="@drawable/button_square_background"
                        android:backgroundTint="@color/menu_blue"
                        android:minHeight="80dp"
                        android:contentDescription="@string/add_contact_button_desc"
                        android:elevation="4dp" />

                </LinearLayout>

                <!-- 提示文字 - 更大更清晰 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/phone_examples"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginTop="8dp"
                    android:contentDescription="電話號碼格式示例" />

            </LinearLayout>

            <!-- 緊急聯絡人列表卡片 -->
            <LinearLayout
                android:id="@+id/contactsSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="24dp"
                android:layout_marginBottom="20dp"
                android:elevation="4dp"
                android:minHeight="200dp">

                <!-- 標題 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/emergency_contacts_list_title"
                    android:textColor="@color/primary_blue"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp"
                    android:minHeight="32dp"
                    android:contentDescription="緊急聯絡人列表標題" />

                <!-- 聯絡人列表 -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/contactsRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="100dp"
                    android:contentDescription="@string/contacts_list_desc"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>

            <!-- 訊息預覽卡片 -->
            <LinearLayout
                android:id="@+id/messageSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="24dp"
                android:layout_marginBottom="20dp"
                android:elevation="4dp"
                android:minHeight="180dp">

                <!-- 標題 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/emergency_message_preview"
                    android:textColor="@color/primary_blue"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp"
                    android:minHeight="32dp"
                    android:contentDescription="緊急訊息預覽標題" />

                <!-- 訊息內容 - 更大字體，易讀 -->
                <TextView
                    android:id="@+id/messagePreviewText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/emergency_message_content"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:lineSpacingMultiplier="1.5"
                    android:background="@drawable/result_background"
                    android:padding="20dp"
                    android:minHeight="100dp"
                    android:contentDescription="緊急求助訊息預覽" />

            </LinearLayout>

            <!-- 測試和完成按鈕卡片 -->
            <LinearLayout
                android:id="@+id/testSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="24dp"
                android:layout_marginBottom="20dp"
                android:elevation="4dp"
                android:minHeight="300dp">

                <!-- 標題 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/test_emergency_function"
                    android:textColor="@color/primary_blue"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp"
                    android:minHeight="32dp"
                    android:contentDescription="測試緊急功能標題" />

                <!-- 測試按鈕 - 大紅色按鈕，突出顯示 -->
                <Button
                    android:id="@+id/testEmergencyButton"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:text="@string/test_emergency_assistance"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/emergency_button_background"
                    android:backgroundTint="@null"
                    android:minHeight="90dp"
                    android:contentDescription="@string/test_emergency_button_desc"
                    android:elevation="6dp"
                    android:layout_marginBottom="16dp" />

                <!-- 提示文字 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/test_mode_warning"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="24dp"
                    android:contentDescription="測試模式說明" />

                <!-- 完成設置按鈕 - 大按鈕 -->
                <Button
                    android:id="@+id/setupCompleteButton"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:text="@string/complete_setup"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/button_square_background"
                    android:backgroundTint="@color/menu_blue"
                    android:minHeight="90dp"
                    android:contentDescription="@string/setup_complete_button_desc"
                    android:elevation="6dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
